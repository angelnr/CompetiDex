# Ejecutar con: cp .env.example .env y ajustar valores
# Solo .env.example se commitea. Nunca commitear .env real.

NODE_ENV=development
PORT=3100

# PokeAPI
POKEAPI_BASE=https://pokeapi.co/api/v2
POKEAPI_CACHE_TTL_S=86400

# Redis (servicio definido en docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Prisma / SQLite local (futura migración a Postgres)
DATABASE_URL="file:./dev.db"

# UI
NEXT_PUBLIC_APP_NAME=CompetiDex