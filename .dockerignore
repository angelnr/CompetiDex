# -----------------------------
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal
*.db
*.db-journal
docker-data

# -----------------------------
# Env & secrets (only ship example)
# -----------------------------
.env
.env.*
!.env.example

